# ============================================================
# QuantMind .gitignore — NEVER commit secrets or large files
# ============================================================

# --- Secrets (NEVER commit real keys) ---
.env
*.env
.env.local
.env.production
!.env.example

# --- Python virtual environment ---
.venv/
venv/
env/
ENV/
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd
.Python

# --- Build artifacts ---
build/
dist/
*.egg-info/
.eggs/
*.egg
*.whl

# --- Testing & Coverage ---
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
*.log
coverage.xml

# --- ChromaDB local data (too large, machine-specific) ---
data/
*.sqlite3
*.db
chroma/

# --- IDE ---
.vscode/settings.json
.vscode/launch.json
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# --- Node.js (for MERN layer in Phase 4) ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.next/
out/

# --- ML Model weights (too large for git) ---
*.bin
*.safetensors
*.pt
*.pth
models/
sentence_transformers/

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb

# --- macOS ---
.DS_Store
.AppleDouble
.LSOverride
