# ============================================================
# QuantMind Server — Environment Variables Template
# Copy to .env and fill in your values. NEVER commit .env.
# ============================================================

# --- Server ---
PORT=5000
NODE_ENV=development

# --- MongoDB Atlas (Free 512MB: https://mongodb.com/atlas) ---
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/quantmind

# --- FastAPI Backend URL ---
PYTHON_API_URL=http://localhost:8000

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
